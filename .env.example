# RPC Configuration
# You can specify a single RPC URL
RPC_URL=http://127.0.0.1:8545

# Or multiple RPC URLs (numbered) - each can be comma-separated for pool per chain
# RPC_URL_1=http://127.0.0.1:8545,http://127.0.0.1:8546
# RPC_URL_2=https://mainnet.infura.io/v3/YOUR_INFURA_KEY,https://eth-backup.example.com
# RPC_URL_3=https://polygon-rpc.com

# Hot-reloadable config file for RPC pool (optional, default: rpc_config.json)
# RPC_CONFIG_FILE=rpc_config.json

# Default Ethereum account for write operations
# This should be an account you control on the connected network
ETH_ACCOUNT=0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Contract Configuration
# These can be auto-detected from deployment.json, but can be overridden here
# CONTRACT_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3
# CHAIN_ID=1337
